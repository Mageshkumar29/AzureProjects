{
	"name": "dataflow2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "SourceDS",
						"type": "DatasetReference"
					},
					"name": "source"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DestinationDS",
						"type": "DatasetReference"
					},
					"name": "sink"
				}
			],
			"transformations": [
				{
					"name": "aggregate",
					"description": "Gettting Total sales of the products"
				}
			],
			"scriptLines": [
				"source(output(",
				"          OrderID as short,",
				"          OrderDate as date,",
				"          CustomerID as string,",
				"          ProductID as string,",
				"          ProductName as string,",
				"          PaymentType as string,",
				"          Quantity as short,",
				"          UnitPrice as integer,",
				"          TotalAmount as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source",
				"source aggregate(groupBy(ProductID,",
				"          ProductName),",
				"     TotalSalesOfProd = sum(TotalAmount)) ~> aggregate",
				"aggregate sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink"
			]
		}
	}
}